<div class="left-menu-container">
    <div class="logo-headers">
        <div class="img-logo-box">
            <img src="{{ asset('images/logo.jpg') }}" alt="logo">
        </div>
        <h1 class="logo-text"><span>O</span>pen<span>B</span>ooks</h1>
    </div>
    <div class="menu-box">
        <ul class="menu">
            <li>
                <i class="fa-regular fa-heart"></i>
                <a href="{{ url('favorite_index') }}">Ulubione</a>
            </li>
            <li>
                <i class="fa-solid fa-table-cells-large"></i>
                <a href="{{ url('category_index') }}">Kategorie</a></li>
            <li>
                <i class="fa-solid fa-book"></i>
                <a href="{{ url('book_index') }}">Książki</a>
            </li>
            <hr>
            <li>
                <i class="fa-brands fa-readme"></i>
                <a href="{{ url('rental_index') }}">Wypożyczenia</a>
            </li>
            {% if is_granted('ROLE_ADMIN') %}
                <hr>
                <li>
                    <i class="fa-solid fa-users"></i>
                    <a href="{{ url('book_queue_index') }}">Kolejka</a>
                </li>
                <li>
                    <i class="fa-solid fa-ticket"></i>
                    <a href="{{ url('rental_tokens_index') }}">Tokeny</a>
                </li>
                <li>
                    <i class="fa-solid fa-users"></i>
                    <a href="{{ url('book_admin') }}">Książki - zbiór</a>
                </li>
                <li>
                    <i class="fa-solid fa-users"></i>
                    <a href="{{ url('rental_admin') }}">Wypożyczenia - zbiór</a>
                </li>
            {% endif %}
         </ul>
    </div>
    {% if newestBook %}
        <div class="new-book-box">
            <div class="header-box">
                <h2>Nowość</h2>
                <div class="category-info">
                    <p style="background-color:{{newestBook.category.color}}70">{{ newestBook.category.title }}</p>
                </div>
            </div>
            <div class="flex-box">
                <div class="white-bg">
                    <div class="img-title-content">
                        <div class="new-book-img">
                            <img src="{{ asset(newestBook.getImagePath) }}" alt="book image">
                        </div>
                        <p>{{ newestBook.title }} &#9679; {{ newestBook.writer }} &#9679; {{ newestBook.yearOfRelease }}</p>
                    </div>
                </div>
                <p>{{ newestBook.description }}</p>
            </div>
        </div>   
    {% endif %}
</div>
<div class="right-container">
    <div class="top-menu-container">
        <ul class="desktop-menu">
            <li>
                <i class="fa-regular fa-circle-user"></i>
            </li>
            {% if app.user %}
                <li class="login-icon">
                    <a href="{{ url('app_logout') }}">
                        <i class="fa-solid fa-right-from-bracket"></i>
                    </a>
                </li>
                <li>
                    <a href="">{{ app.user.email }}</a>
                </li>
            {% else %}
                <li class="login-icon">
                    <a href="{{ url('app_login') }}">Zaloguj</a>
                </li>
            {% endif %}
        </ul>
        <i class="fa-solid fa-bars hamburger-icon"></i>
        <div class="mobile-menu">
            <div class="drop-down">
                <ul>
                    <li class="flex">
                        <i class="fa-solid fa-angle-right"></i>
                        <a href="{{ url('favorite_index') }}">Ulubione</a>
                    </li>
                    <li class="flex">
                        <i class="fa-solid fa-angle-right"></i>
                        <a href="{{ url('category_index') }}">Kategorie</a></li>
                    <li class="flex">
                        <i class="fa-solid fa-angle-right"></i>
                        <a href="{{ url('book_index') }}">Książki</a>
                    </li>
                    <hr>
                    <li class="flex">
                        <i class="fa-solid fa-angle-right"></i>
                        <a href="{{ url('rental_index') }}">Wypożyczenia</a>
                    </li>
                    {% if is_granted('ROLE_ADMIN') %}
                        <hr>
                        <li class="flex">
                            <i class="fa-solid fa-angle-right"></i>
                            <a href="{{ url('book_queue_index') }}">Kolejka</a>
                        </li>
                        <li class="flex">
                            <i class="fa-solid fa-angle-right"></i>
                            <a href="{{ url('rental_tokens_index') }}">Tokeny</a>
                        </li>
                        <li class="flex">
                            <i class="fa-solid fa-angle-right"></i>
                            <a href="{{ url('rental_admin') }}">Wypożyczenia - zbiór </a>
                        </li>
                        <li class="flex">
                            <i class="fa-solid fa-angle-right"></i>
                            <a href="{{ url('book_admin') }}">Książki - zbiór </a>
                        </li>
                    {% endif %}
                    <li class="hide-until-768px">
                        {% if app.user %}
                        <a href="{{ url('app_logout') }}">
                            <i class="fa-solid fa-right-from-bracket"></i>
                            Wyloguj
                        </a>
                        {% else %}
                            <li>
                                <a href="{{ url('app_login') }}">Zaloguj</a>
                            </li>
                        {% endif %}
                    </li>
                </ul>
            </div>
        </div>
    </div>
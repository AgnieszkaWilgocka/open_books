{% extends 'base.html.twig' %}

{% block layout %}
    <div class="app-container">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="flash flash-{{ label }}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}
        {% include "/main/_navbar.html.twig" %}
        <div class="page-container">
            {% block body %}{% endblock %}
        </div>
    </div>
{% endblock %}
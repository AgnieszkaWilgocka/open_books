{% extends 'base.html.twig' %}

{% block body %}
  <h1>Rentals</h1>
  {% if rentals|length %}
    <table class="table table-striped">
      <thead>
        <tr>
          <th>Id</th>
          <th>Rented at</th>
          <th>Updated at</th>
          <th>Book</th>
          <th>Status</th>
          <th>Returned at</th>
          <th>Owner </th>
          <th>Deadline</th>
        </tr>
      </thead>
      <tbody>
        {% for rental in rentals %}
          <tr>
            <td>{{ rental.id }}</td>
            <td>{{ rental.rentedAt|date('F jS') }}</td>
            <td>{{ rental.updatedAt|date('F jS') }}</td>
            <td>{{ rental.book.title }}</td>
            <td>{{ rental.returnedAt ? 'Returned' : 'Borrowed' }}</td>
            <td>{{ rental.returnedAt ? rental.returnedAt|date('Y-m-d') : '-' }}</td>
            <td>{{ rental.owner.email }}</td>
            <td>{{ rental.deadline|date('F jS') }}</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  {% else %}
    <p>No rentals found</p>
  {% endif %}
{% endblock %}
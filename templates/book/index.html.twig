{% extends 'base.html.twig' %}

{% block title %}
    Books list
{% endblock %}

{% block body %}
    <h1>Books list</h1>

     {% for book in books %}
        {% if book.imageFileName %}
            <img src="{{ asset(book.getImagePath) }}" alt="{{ book.title }}">
        {% else %}
            <p>No file uploaded</p>
        {% endif %}
        <p>Id: {{ book.id }}</p>
        <p>Title: {{ book.title }}</p>
        <p>Created at: {{ book.createdAt|date('Y-m-d') }}</p>
        <p>Updated at: {{ book.updatedAt|date('Y-m-d') }}</p>
        <p>Status: {{ book.rentals|length ? 'Borrowed' : 'Available' }}</p>
        <p>Year of release: {{ book.yearOfRelease }}</p>
        <p>Pages: {{ book.pages }}</p>
        <p>Category: {{ book.category.title }}</p> 
    {% endfor %} 
{% endblock %}

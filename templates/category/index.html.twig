{% extends 'base.html.twig' %}

{% block body %}
    <h1>Categories</h1>
    {% if categories|length %}
      <table class="table table-striped">
        <thead>
          <tr>
            <th>Id</th>
            <th>Name</th>
          </tr>
        </thead>
        <tbody>
          {% for category in categories %}
            <tr>
              <td>{{ category.id }}</td>
              <td>{{ category.title }}</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    {% else %}
      <p>No categories found</p>
    {% endif %}
{% endblock %}